---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with the Investment Banker editorial team at Swiss Finance Institute for questions about investment banking careers.">
  <div class="max-w-3xl mx-auto text-center">
    <h1 class="text-3xl font-bold mb-6">Get in Touch</h1>
    <p class="text-lg text-gray-600 mb-8">Have questions about breaking into investment banking, preparing for interviews, or navigating your career? We would like to hear from you.</p>
    <div class="bg-white border border-gray-200 rounded-lg p-8">
      <h2 class="text-xl font-bold mb-4">Contact Us</h2>
      <p class="text-gray-600 mb-6">For editorial inquiries, corrections, or general questions about investment banking careers.</p>
      <a href="mailto:contact@swissfinanceinstitute.ai" class="bg-blue-700 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-800 transition-colors inline-block">contact@swissfinanceinstitute.ai</a>
    </div>
  </div>
</BaseLayout>
