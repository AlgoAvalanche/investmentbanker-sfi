---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Schedule a consultation with Sanjay Gupta to discuss your investment banking career, interview preparation, or professional development.">
  <div class="max-w-3xl mx-auto text-center">
    <h1 class="text-3xl font-bold mb-6">Get in Touch</h1>
    <p class="text-lg text-gray-600 mb-8">Have questions about breaking into investment banking, preparing for interviews, or navigating your career? Schedule a consultation.</p>
    <div class="bg-white border border-gray-200 rounded-lg p-8">
      <h2 class="text-xl font-bold mb-4">Schedule a Call</h2>
      <p class="text-gray-600 mb-6">Book a 30-minute consultation to discuss your specific situation and get actionable advice.</p>
      <a href="mailto:info@swissfinanceinstitute.ai" class="bg-blue-700 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-800 transition-colors inline-block">Contact Us</a>
    </div>
  </div>
</BaseLayout>
