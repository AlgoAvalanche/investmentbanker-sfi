---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  type?: 'website' | 'article';
  date?: string;
  author?: string;
  breadcrumbs?: { name: string; url: string }[];
}

const { title, description, type = 'website', date, author, breadcrumbs = [] } = Astro.props;

const categories = [
  { name: 'Technical', slug: 'technical' },
  { name: 'Interview Prep', slug: 'interview-prep' },
  { name: 'Job Search', slug: 'job-search' },
  { name: 'Industry', slug: 'industry' },
  { name: 'Recruiting Insider', slug: 'recruiting-insider' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/favicon.ico" />
  <SEO title={title} description={description} type={type} date={date} author={author} breadcrumbs={breadcrumbs} />
</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-gray-900 tracking-tight">Investment Banker</a>
      <div class="hidden md:flex items-center gap-6 text-sm">
        {categories.map(c => (
          <a href={`/${c.slug}/`} class="text-gray-600 hover:text-gray-900 transition-colors">{c.name}</a>
        ))}
        <a href="/about/" class="text-gray-600 hover:text-gray-900 transition-colors">About</a>
        <a href="https://swissfinanceinstitute.ai" target="_blank" rel="noopener noreferrer" class="bg-blue-700 text-white px-4 py-1.5 rounded text-sm font-medium hover:bg-blue-800 transition-colors">Apply to SFI</a>
      </div>
      <button id="mobileMenu" class="md:hidden text-gray-600 text-2xl">&#9776;</button>
    </nav>
    <div id="mobileNav" class="hidden md:hidden border-t border-gray-100 px-4 py-3 space-y-2 bg-white">
      {categories.map(c => (
        <a href={`/${c.slug}/`} class="block text-sm text-gray-600 py-1">{c.name}</a>
      ))}
      <a href="/about/" class="block text-sm text-gray-600 py-1">About</a>
      <a href="https://swissfinanceinstitute.ai" target="_blank" rel="noopener noreferrer" class="block text-sm text-blue-700 font-medium py-1">Apply to SFI</a>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 py-8">
    <slot />
  </main>

  <footer class="bg-gray-900 text-gray-400 mt-16">
    <div class="max-w-6xl mx-auto px-4 py-12">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <h4 class="text-white font-bold mb-3">Investment Banker</h4>
          <p class="text-sm">Expert insights on investment banking careers, technical skills, and industry knowledge. Published by Swiss Finance Institute.</p>
        </div>
        <div>
          <h4 class="text-white font-bold mb-3">Categories</h4>
          <div class="space-y-1">
            {categories.map(c => (
              <a href={`/${c.slug}/`} class="block text-sm hover:text-white transition-colors">{c.name}</a>
            ))}
          </div>
        </div>
        <div>
          <h4 class="text-white font-bold mb-3">Resources</h4>
          <div class="space-y-1">
            <a href="/about/" class="block text-sm hover:text-white transition-colors">About</a>
            <a href="/contact/" class="block text-sm hover:text-white transition-colors">Contact</a>
            <a href="/sitemap-index.xml" class="block text-sm hover:text-white transition-colors">Sitemap</a>
          </div>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-6 text-sm text-center">
        &copy; {new Date().getFullYear()} Swiss Finance Institute. All rights reserved.
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('mobileMenu')?.addEventListener('click', () => {
      document.getElementById('mobileNav')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
