---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  author: string;
  category: string;
  primary_keyword: string;
}

const { title, description, date, author, category, primary_keyword } = Astro.props;

const categoryNames: Record<string, string> = {
  'technical': 'Technical',
  'interview-prep': 'Interview Prep',
  'job-search': 'Job Search',
  'industry': 'Industry',
  'recruiting-insider': 'Recruiting Insider',
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: categoryNames[category] || category, url: `/${category}/` },
  { name: title, url: Astro.url.href },
];
---

<BaseLayout title={title} description={description} type="article" date={date} author={author} breadcrumbs={breadcrumbs}>
  <article class="max-w-3xl mx-auto">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">Home</a>
      <span class="mx-1">/</span>
      <a href={`/${category}/`} class="hover:text-gray-700">{categoryNames[category] || category}</a>
      <span class="mx-1">/</span>
      <span class="text-gray-700">{title}</span>
    </nav>

    <header class="mb-8">
      <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
        <a href={`/${category}/`} class="bg-blue-100 text-blue-800 px-2 py-0.5 rounded text-xs font-medium">{categoryNames[category] || category}</a>
        <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">{title}</h1>
      <p class="text-lg text-gray-600">{description}</p>
      <div class="flex items-center gap-3 mt-4 pt-4 border-t border-gray-100">
        <div class="w-10 h-10 bg-blue-700 rounded-full flex items-center justify-center text-white font-bold text-sm">SG</div>
        <div>
          <div class="font-medium text-sm">{author}</div>
          <div class="text-xs text-gray-500">Former Managing Director, Investment Banking</div>
        </div>
      </div>
    </header>

    <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-a:text-blue-700 prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg">
      <slot />
    </div>
  </article>
</BaseLayout>
